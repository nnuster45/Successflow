<mxfile host="app.diagrams.net" type="device">
  <diagram id="SuccessFlow-File-Links" name="SuccessFlow File & Link Schema">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- CONTAINER: ROOT DIRECTORY -->
        <mxCell id="root_dir" value="ROOT DIRECTORY" style="swimlane;whiteSpace=wrap;html=1;startSize=23;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="220" height="120" as="geometry" />
        </mxCell>
        <mxCell id="f_index" value="index.html&#xa;(Main Entry)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontStyle=1" vertex="1" parent="root_dir">
          <mxGeometry x="30" y="40" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- CONTAINER: ASSETS (Dependencies) -->
        <mxCell id="assets_dir" value="ASSETS (/assets/)" style="swimlane;whiteSpace=wrap;html=1;startSize=23;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="220" height="240" as="geometry" />
        </mxCell>
        <mxCell id="f_css" value="css/main.css&#xa;(Tailwind Styles)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="assets_dir">
          <mxGeometry x="30" y="40" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="f_js_main" value="js/main.js&#xa;(UI Logic / Form)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="assets_dir">
          <mxGeometry x="30" y="105" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="f_js_i18n" value="js/i18n.js&#xa;(Translation Engine)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="assets_dir">
          <mxGeometry x="30" y="170" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- CONTAINER: SERVICES (Sub-pages) -->
        <mxCell id="serv_dir" value="SERVICES (/services/)" style="swimlane;whiteSpace=wrap;html=1;startSize=23;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="360" y="40" width="300" height="120" as="geometry" />
        </mxCell>
        <mxCell id="f_serv_index" value="[service-name]/index.html&#xa;(Service Detail Page)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="serv_dir">
          <mxGeometry x="30" y="40" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- CONTAINER: PORTFOLIO (Case Studies) -->
        <mxCell id="port_dir" value="PORTFOLIO (/portfolio/)" style="swimlane;whiteSpace=wrap;html=1;startSize=23;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="360" y="240" width="300" height="120" as="geometry" />
        </mxCell>
        <mxCell id="f_port_index" value="[project-name]/index.html&#xa;(Case Study Page)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;" vertex="1" parent="port_dir">
          <mxGeometry x="30" y="40" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- NAVIGATION LINKS (Blue Lines) -->
        <mxCell id="l_nav_1" value="navigates to" style="endArrow=block;html=1;exitX=1;exitY=0.25;entryX=0;entryY=0.5;strokeColor=#0050ef;fontColor=#0050ef;fontSize=11;" edge="1" parent="1" source="f_index" target="f_serv_index" />
        <mxCell id="l_nav_2" value="navigates to" style="endArrow=block;html=1;exitX=1;exitY=0.75;entryX=0;entryY=0.5;strokeColor=#0050ef;fontColor=#0050ef;fontSize=11;" edge="1" parent="1" source="f_index" target="f_port_index" />
        <mxCell id="l_nav_3" value="cross ref" style="endArrow=classic;startArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#0050ef;fontColor=#0050ef;fontSize=11;dashed=1;" edge="1" parent="1" source="f_serv_index" target="f_port_index" />
        <mxCell id="l_nav_home" value="back to home" style="endArrow=block;html=1;exitX=0.25;exitY=0;entryX=0.75;entryY=0;strokeColor=#0050ef;fontColor=#0050ef;fontSize=11;" edge="1" parent="1" source="f_serv_index" target="f_index" />

        <!-- FILE DEPENDENCIES (Dashed Lines) -->
        <mxCell id="d_1" value="includes" style="endArrow=open;html=1;dashed=1;exitX=0.25;exitY=1;entryX=0.5;entryY=0;strokeColor=#666666;fontSize=10;" edge="1" parent="1" source="f_index" target="assets_dir" />
        <mxCell id="d_2" value="includes" style="endArrow=open;html=1;dashed=1;exitX=0.75;exitY=1;entryX=0.5;entryY=0;strokeColor=#666666;fontSize=10;" edge="1" parent="1" source="f_port_index" target="assets_dir" />
        <mxCell id="d_3" value="includes" style="endArrow=open;html=1;dashed=1;exitX=0.5;exitY=1;entryX=1;entryY=0.5;strokeColor=#666666;fontSize=10;" edge="1" parent="1" source="f_serv_index" target="assets_dir" />

        <!-- EXTERNAL DATA -->
        <mxCell id="ext_n8n" value="n8n Webhook&#xa;(External API)" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="680" y="400" width="140" height="80" as="geometry" />
        </mxCell>
        <mxCell id="l_data" value="sends JSON" style="endArrow=block;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#9673a6;fontColor=#9673a6;fontSize=11;" edge="1" parent="1" source="f_js_main" target="ext_n8n" />
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>